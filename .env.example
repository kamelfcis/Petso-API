DEBUG=True
SECRET_KEY=change-me-in-production
# Use at least 32 characters for production (PyJWT / HS256). Shorter keys are padded for JWT only in settings.
# Optional (demo / weak): set to 1 to speed up signup/login on slow CPUs (lower PBKDF2 iterations)
# PETSO_FAST_PASSWORD_HASHING=0
DATABASE_URL=sqlite:///db.sqlite3
# Redis: used by Django Channels (chat/WebSockets), not Celery
REDIS_URL=redis://localhost:6379/1
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# --- VPS production (this project’s server: 95.216.63.81) ---
# Copy the block you need into `.env` on the VPS (same folder as manage.py), then restart the app.
#
# A) API on port 8000 only (e.g. gunicorn 0.0.0.0:8000, no nginx yet)
# DEBUG=False
# SECRET_KEY=use-a-long-random-string-not-this-one
# ALLOWED_HOSTS=95.216.63.81,localhost,127.0.0.1
# CSRF_TRUSTED_ORIGINS=http://95.216.63.81:8000
# PETSO_PUBLIC_BASE_URL=http://95.216.63.81:8000
# SERVE_MEDIA_FROM_DJANGO=True
# USE_X_FORWARDED_HOST=True
#
# B) nginx on port 80 (HTTP) proxying to gunicorn on 127.0.0.1:8000 — use no :8000 in URLs
# DEBUG=False
# SECRET_KEY=use-a-long-random-string-not-this-one
# ALLOWED_HOSTS=95.216.63.81,localhost,127.0.0.1
# CSRF_TRUSTED_ORIGINS=http://95.216.63.81
# PETSO_PUBLIC_BASE_URL=http://95.216.63.81
# SERVE_MEDIA_FROM_DJANGO=True
# USE_X_FORWARDED_HOST=True
#
# C) HTTPS with a domain — set ALLOWED_HOSTS / CSRF / PETSO_PUBLIC_BASE_URL to https://yourdomain.com
#
# Max upload size (MB) for multipart images; nginx client_max_body_size should be >= this. Sample: deployment/nginx-petso.sample.conf
# PETSO_MAX_UPLOAD_MB=32
#
# nginx (in front of Django): client_max_body_size 32m; proxy_set_header Host $host;
#   proxy_set_header X-Forwarded-Proto $scheme; proxy_set_header X-Forwarded-Host $host;
# Firewall: sudo ufw allow 8000/tcp   # or 80,443 if using nginx

# One-off production admin (local only; do not commit real values)
# BOOTSTRAP_ADMIN_EMAIL=
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ADMIN_NAME=Admin
