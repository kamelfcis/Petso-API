DEBUG=True
SECRET_KEY=change-me-in-production
# Optional (demo / weak): set to 1 to speed up signup/login on slow CPUs (lower PBKDF2 iterations)
# PETSO_FAST_PASSWORD_HASHING=0
DATABASE_URL=sqlite:///db.sqlite3
# Redis: used by Django Channels (chat/WebSockets), not Celery
REDIS_URL=redis://localhost:6379/1
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# --- VPS / reverse proxy (production) ---
# DEBUG=False
# ALLOWED_HOSTS=api.yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://api.yourdomain.com
# Trust X-Forwarded-Host from nginx (defaults to True when DEBUG=False)
# USE_X_FORWARDED_HOST=True
# Public URL of this API (no trailing slash). Fixes image/image_url in JSON if Host is wrong behind proxy.
# PETSO_PUBLIC_BASE_URL=https://api.yourdomain.com
# Serve /media/ from Django. Use True unless nginx has: location /media/ { alias /path/to/Petso/media/; }
# SERVE_MEDIA_FROM_DJANGO=True
# nginx tips: client_max_body_size 10m; proxy_set_header Host $host;
#   proxy_set_header X-Forwarded-Proto $scheme; proxy_set_header X-Forwarded-Host $host;

# One-off production admin (local only; do not commit real values)
# BOOTSTRAP_ADMIN_EMAIL=
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ADMIN_NAME=Admin
